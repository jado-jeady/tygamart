# Strapi CMS (admin_side) — catalog + orders
# Required in Render (and Docker build) so Next.js allows Strapi Cloud media URLs.
NEXT_PUBLIC_STRAPI_URL=https://classic-thrill-275a63a313.strapiapp.com

# Public storefront URL (used in WhatsApp order links). In production set your real https domain.
# NEXT_PUBLIC_SITE_URL=https://your-shop.com

# Set to "false" to load catalog from Strapi instead of mock data
NEXT_PUBLIC_USE_MOCK_DATA=false

# Legacy Supabase (optional — only used if mock is off and Strapi URL is unset)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
