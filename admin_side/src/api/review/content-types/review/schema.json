{
  "kind": "collectionType",
  "collectionName": "reviews",
  "info": {
    "singularName": "review",
    "pluralName": "reviews",
    "displayName": "Customer review",
    "description": "Star ratings and written feedback from shoppers"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "customer_name": {
      "type": "string",
      "required": true,
      "description": "Name shown on the product page"
    },
    "stars": {
      "type": "integer",
      "required": true,
      "min": 1,
      "max": 5,
      "description": "Rating from 1 to 5 stars"
    },
    "title": {
      "type": "string",
      "description": "Short headline for the review"
    },
    "comment": {
      "type": "text",
      "required": true,
      "description": "What the customer wrote"
    },
    "show_on_website": {
      "type": "boolean",
      "default": true,
      "description": "Untick to hide this review from the shop"
    },
    "product": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::product.product",
      "inversedBy": "reviews",
      "description": "Which product this review is about"
    }
  }
}
