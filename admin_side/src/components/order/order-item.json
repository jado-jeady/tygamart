{
  "collectionName": "components_order_order_items",
  "info": {
    "displayName": "Product in order",
    "description": "One product the customer ordered"
  },
  "options": {},
  "attributes": {
    "product_name": {
      "type": "string",
      "required": true,
      "description": "Product name"
    },
    "size": {
      "type": "string",
      "description": "Size"
    },
    "color": {
      "type": "string",
      "description": "Color"
    },
    "item_code": {
      "type": "string",
      "description": "Your item code for this size/color"
    },
    "how_many": {
      "type": "integer",
      "required": true,
      "min": 1,
      "description": "How many pieces"
    },
    "price_each": {
      "type": "decimal",
      "required": true,
      "description": "Price for one piece (RWF)"
    },
    "bought_as": {
      "type": "enumeration",
      "enum": ["one_piece", "many_pieces"],
      "default": "one_piece",
      "description": "Did they buy one piece, or many at the lower price?"
    },
    "row_total": {
      "type": "decimal",
      "required": true,
      "description": "How many × price each (RWF)"
    },
    "image_url": {
      "type": "text",
      "description": "Product image URL at the time of order (optional)"
    }
  }
}
